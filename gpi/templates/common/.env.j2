# Variables d'environnement — NE PAS COMMITTER CE FICHIER
DEBUG=true
PORT={{ port }}
SECRET_KEY={{ secret_key }}
{% if "database-postgres" in modules %}
DATABASE_URL=postgresql://user:password@localhost:5432/{{ project_name }}
{% elif "database-mysql" in modules %}
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/{{ project_name }}
{% elif "database-sqlite" in modules %}
DATABASE_URL=sqlite:///./{{ project_name }}.db
{% endif %}
{% if "cache-redis" in modules %}
REDIS_URL=redis://localhost:6379/0
{% endif %}
